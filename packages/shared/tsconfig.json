{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "baseUrl": ".",
        "paths": {
            "#shared/*": ["src/*"]
        }
    },
    "include": ["src/**/*"]
}
