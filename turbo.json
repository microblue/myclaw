{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "test": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "eslint.config.js"],
            "outputs": []
        },
        "check": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"],
            "outputs": []
        }
    }
}
