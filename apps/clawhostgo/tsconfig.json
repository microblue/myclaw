{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "#i18n/*": ["../../packages/i18n/src/*"],
            "#shared/*": ["../../packages/shared/src/*"]
        }
    },
    "include": [
        "src/main.ts",
        "src/preload.ts",
        "src/main/**/*",
        "src/ts/**/*"
    ],
    "exclude": ["src/renderer"]
}
