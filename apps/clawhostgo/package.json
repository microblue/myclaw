{
    "name": "myclawgo",
    "productName": "ClawHostGo",
    "version": "0.0.150",
    "private": true,
    "main": ".vite/build/main.js",
    "scripts": {
        "postinstall": "node scripts/patch-electron.js",
        "dev": "rm -rf node_modules/.vite && electron-forge start",
        "build": "electron-forge make",
        "package": "electron-forge package",
        "download-node": "bash scripts/download-node.sh",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "pnpm typecheck && pnpm lint"
    },
    "dependencies": {
        "@openclaw/i18n": "workspace:*",
        "@openclaw/shared": "workspace:*",
        "@phosphor-icons/react": "^2.1.10",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-query": "^5.60.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "firebase": "^12.9.0",
        "framer-motion": "^12.29.2",
        "node-forge": "^1.3.1",
        "node-pty": "^1.1.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.28.0",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.0",
        "@electron-forge/maker-deb": "^7.11.0",
        "@electron-forge/maker-dmg": "^7.11.0",
        "@electron-forge/maker-zip": "^7.11.0",
        "@electron-forge/plugin-vite": "^7.11.0",
        "@electron-forge/shared-types": "^7.11.0",
        "@types/node": "^22.9.0",
        "@types/node-forge": "^1.3.11",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.3",
        "autoprefixer": "^10.4.20",
        "electron": "^34.0.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.15",
        "typescript": "^5.6.3",
        "vite": "^5.4.11"
    }
}
