{
    "expo": {
        "name": "ClawHost",
        "slug": "myclaw",
        "version": "0.0.1",
        "orientation": "portrait",
        "userInterfaceStyle": "dark",
        "backgroundColor": "#0a0a0f",
        "newArchEnabled": true,
        "splash": {
            "backgroundColor": "#0a0a0f"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.myclaw.one".app"
        },
        "android": {
            "package": "com.myclaw.one".app",
            "adaptiveIcon": {
                "backgroundColor": "#0a0a0f"
            }
        },
        "scheme": "myclaw",
        "platforms": ["ios", "android"],
        "plugins": ["expo-font"]
    }
}
